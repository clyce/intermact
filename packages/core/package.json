{
  "name": "@intermact/core",
  "version": "1.0.0",
  "description": "Framework-free core: object model, retained-mode seekable timeline, geometry, reactive layer.",
  "license": "MIT",
  "author": "clyce",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clyce/intermact.git",
    "directory": "packages/core"
  },
  "homepage": "https://clyce.github.io/intermact/",
  "bugs": "https://github.com/clyce/intermact/issues",
  "keywords": [
    "manim",
    "visualization",
    "animation",
    "timeline",
    "geometry",
    "math"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "earcut": "^3.0.1",
    "mathjax-full": "^3.2.2",
    "opentype.js": "^2.0.0"
  },
  "devDependencies": {
    "@fontsource/dejavu-sans": "^5.2.5",
    "@types/earcut": "^2.1.4"
  }
}
