{
  "name": "intermact",
  "version": "0.1.0",
  "private": true,
  "description": "Interactive 3D Manim alternative built on React Three Fiber.",
  "type": "module",
  "packageManager": "pnpm@10.2.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench --run",
    "depcruise": "depcruise packages --config .dependency-cruiser.cjs",
    "ci": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run depcruise && pnpm run build",
    "dev:examples": "pnpm --filter @intermact/examples run dev",
    "dev:site": "node scripts/dev-site.mjs",
    "gen:reference": "pnpm --filter @intermact/docs run gen:reference",
    "dev:docs": "pnpm --filter @intermact/docs run dev",
    "build:docs": "pnpm --filter @intermact/docs run build",
    "build:site": "node scripts/build-site.mjs",
    "preview:docs": "pnpm --filter @intermact/docs run preview",
    "preview:site": "node scripts/verify-site-dist.mjs && pnpm run preview:docs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "dependency-cruiser": "^16.8.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.8"
  }
}
